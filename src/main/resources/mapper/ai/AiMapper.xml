<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xd.smartworksite.ai.mapper.AiMapper">

    <resultMap id="ExternalCallLogMap" type="com.xd.smartworksite.ai.domain.ExternalCallLog">
        <id property="id" column="id"/>
        <result property="projectId" column="project_id"/>
        <result property="serviceName" column="service_name"/>
        <result property="callType" column="call_type"/>
        <result property="requestId" column="request_id"/>
        <result property="requestSummary" column="request_summary"/>
        <result property="responseSummary" column="response_summary"/>
        <result property="status" column="status"/>
        <result property="costMs" column="cost_ms"/>
        <result property="errorMessage" column="error_message"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <resultMap id="DataSourceMap" type="com.xd.smartworksite.ai.domain.DataSourceRecord">
        <id property="id" column="id"/>
        <result property="projectId" column="project_id"/>
        <result property="name" column="name"/>
        <result property="dbType" column="db_type"/>
        <result property="jdbcUrl" column="jdbc_url"/>
        <result property="username" column="username"/>
        <result property="passwordCipher" column="password_cipher"/>
        <result property="status" column="status"/>
    </resultMap>

    <insert id="insertExternalCallLog" useGeneratedKeys="true" keyProperty="id">
        insert into external_call_log (
            project_id, service_name, call_type, request_id, request_summary,
            response_summary, status, cost_ms, error_message, created_by, updated_by
        ) values (
            #{projectId}, #{serviceName}, #{callType}, #{requestId}, #{requestSummary},
            #{responseSummary}, #{status}, #{costMs}, #{errorMessage}, 1, 1
        )
    </insert>

    <select id="selectExternalCallLogPage" resultMap="ExternalCallLogMap">
        select id, project_id, service_name, call_type, request_id, request_summary,
               response_summary, status, cost_ms, error_message, created_at
        from external_call_log
        where deleted = 0
        <if test="projectId != null">
            and project_id = #{projectId}
        </if>
        <if test="serviceName != null and serviceName != ''">
            and service_name = #{serviceName}
        </if>
        <if test="callType != null and callType != ''">
            and call_type = #{callType}
        </if>
        <if test="status != null and status != ''">
            and status = #{status}
        </if>
        order by created_at desc, id desc
    </select>

    <select id="selectDataSourceById" resultMap="DataSourceMap">
        select id, project_id, name, db_type, jdbc_url, username, password_cipher, status
        from data_source
        where id = #{dataSourceId}
          and project_id = #{projectId}
          and status = 'ENABLED'
          and deleted = 0
    </select>
</mapper>
